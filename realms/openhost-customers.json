{
  "realm": "openhost-customers",
  "enabled": true,
  "displayName": "OpenHost",
  "displayNameHtml": "<div class=\"kc-logo-text\"><span>OpenHost</span></div>",
  "sslRequired": "external",
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "failureFactor": 10,
  "waitIncrementSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "passwordPolicy": "length(12) and notUsername and passwordHistory(3)",
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "accessTokenLifespan": 300,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "attributes": {
    "_comment": "Auth realm for customers of managed OpenHost instances. Registration is disabled until SMTP is configured (Realm settings -> Email); see README.md. OIDC clients for the billing portal / vm-manager / customer dashboards should be created in this realm."
  }
}
